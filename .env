# Jarvis Voice AI Assistant - Environment Variables

# News API Key (get from https://newsapi.org/)
NEWS_API_KEY=your_news_api_key_here

# Weather API Key (get from https://openweathermap.org/)
WEATHER_API_KEY=your_weather_api_key_here

# Stock API Key (get from https://www.alphavantage.co/)
STOCK_API_KEY=your_stock_api_key_here

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Note: For Gmail, use an "App Password" instead of your regular password
# Enable 2-factor authentication and generate an app password at: https://myaccount.google.com/apppasswords
